# Copy this file to .env and replace every placeholder before starting Compose.
POSTGRES_DB=ugorjbe
POSTGRES_USER=ugorjbe
POSTGRES_PASSWORD=replace-with-a-local-database-password

# At least 32 UTF-8 bytes. This example is a placeholder, not a usable signing key.
JWT_SIGNING_KEY=replace-with-a-random-local-key-at-least-32-bytes-long

# Change only when port 8080 is already occupied on the development machine.
ADMIN_WEB_PORT=8080
